# Project URL comes from Supabase Project Connect settings.
EXPO_PUBLIC_SUPABASE_URL=

# Publishable key is client-safe when RLS is configured.
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Local application URL and authentication callback path
EXPO_PUBLIC_APP_URL=http://localhost:8081
EXPO_PUBLIC_AUTH_CALLBACK_PATH=/auth/callback

# =========================================================================
# IMPORTANT SECURITY WARNINGS:
# - Service-role and database credentials must never be added here.
# - Every EXPO_PUBLIC value is visible in the application bundle.
# =========================================================================
